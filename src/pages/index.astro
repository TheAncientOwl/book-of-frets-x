import '#styles/global.css';

import SongsList from '#components/songs-list/SongsList.astro';
import SongsListLayout from '#layouts/SongsListLayout.astro';
import SearchBar from '#components/common/SearchBar.astro';
import AppMenu from '#components/app-menu/AppMenu.astro';
---

<SongsListLayout>
  <AppMenu />
  <div
    id='songs-list-container'
    class='bg-deep-charcoal w-dvw h-dvh overflow-hidden flex justify-center items-center'
  >
    <div
      class='w-xl h-[100dvh]
        max-sm:w-dvw
        rounded-xl max-sm:rounded-none
        flex flex-col gap-4 justify-center items-center
        bg-deep-purple
        p-[1em] max-sm:pt-[1em] max-sm:px-0 max-sm:pb-[0.2em]'
    >
      <div class='flex-none w-[250px] relative flex items-center'>
        <div class='w-full'>
          <SearchBar placeholder='Search song / artist / type...' />
        </div>

        <button
          id='filter-favorites-btn'
          type='button'
          class='absolute left-full ml-2 top-1/2 -translate-y-1/2 p-2 rounded bg-black/5 hover:bg-dark-magenta text-gold hover:text-gold border border-solid border-neon-purple transition-colors cursor-pointer select-none z-10'
          title='Toggle Favorites Only'
          data-active='false'
        >
          {/* Outlined Star Icon */}
          <svg
            id='star-outline'
            xmlns='http://www.w3.org/2000/svg'
            width='18'
            height='18'
            viewBox='0 0 24 24'
            fill='none'
            stroke='currentColor'
            stroke-width='2'
            stroke-linecap='round'
            stroke-linejoin='round'
            class='block'
            ><polygon
              points='12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2'
            ></polygon></svg
          >
          {/* Filled Star Icon */}
          <svg
            id='star-filled'
            xmlns='http://www.w3.org/2000/svg'
            width='18'
            height='18'
            viewBox='0 0 24 24'
            fill='currentColor'
            stroke='currentColor'
            stroke-width='2'
            stroke-linecap='round'
            stroke-linejoin='round'
            class='hidden text-gold'
            ><polygon
              points='12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2'
            ></polygon></svg
          >
        </button>
      </div>

      <div class='flex-1 w-full overflow-y-auto min-h-0 pr-1'>
        <SongsList />
      </div>
    </div>
  </div>
</SongsListLayout>

<script>
  const TOGGLE_STORAGE_KEY = 'book-of-frets-filter-favorites-active';
  const toggleBtn = document.getElementById('filter-favorites-btn');
  const outlineStar = document.getElementById('star-outline');
  const filledStar = document.getElementById('star-filled');

  function updateToggleUI(isActive: boolean) {
    if (!toggleBtn) return;
    toggleBtn.setAttribute('data-active', String(isActive));
    if (isActive) {
      outlineStar?.classList.replace('block', 'hidden');
      filledStar?.classList.replace('hidden', 'block');
    } else {
      outlineStar?.classList.replace('hidden', 'block');
      filledStar?.classList.replace('block', 'hidden');
    }
  }

  // Initialize UI accurately from local storage immediately on load
  const storedFilterState = localStorage.getItem(TOGGLE_STORAGE_KEY) === 'true';
  updateToggleUI(storedFilterState);

  toggleBtn?.addEventListener('click', () => {
    const isActive = toggleBtn.getAttribute('data-active') === 'true';
    const nextState = !isActive;

    updateToggleUI(nextState);
    localStorage.setItem(TOGGLE_STORAGE_KEY, String(nextState));

    document.dispatchEvent(
      new CustomEvent('favorites-toggle', {
        detail: { onlyFavorites: nextState },
      }),
    );
  });
</script>
