import SongCard from '#components/songs-list/SongCard.astro';

import type { TSongsIndexEntry } from '#types/song';
import songsIndexData from '#public/songs/index.json';
const songsIndex = (songsIndexData as { index: TSongsIndexEntry[] }).index;

const AboveTheFoldCount = 12;
---

{
  songsIndex.map((song, index) => (
    <SongCard
      index={index + 1}
      preload={index + 1 <= AboveTheFoldCount}
      title={song.title}
      artists={song.artists}
      directory={song.directory}
      type={song.type}
      chordIDs={song.chordIDs}
    />
  ))
}

<script>
  const songCards = document.querySelectorAll('[data-song-card]');
  const STORAGE_KEY = 'book-of-frets-favorites';
  const TOGGLE_STORAGE_KEY = 'book-of-frets-filter-favorites-active';

  let currentSearchQuery = '';
  // Pull state cleanly dynamically to guard execution race order conditions
  let filterOnlyFavorites = localStorage.getItem(TOGGLE_STORAGE_KEY) === 'true';

  function applyFilters() {
    songCards.forEach(card => {
      const htmlCard = card as HTMLElement;
      const title = (htmlCard.dataset.title || '').toLowerCase();
      const artists = (htmlCard.dataset.artists || '').toLowerCase();
      const types = (htmlCard.dataset.types || '').toLowerCase();
      const isFavorited = htmlCard.getAttribute('data-favorited') === 'true';

      const matchesSearch =
        !currentSearchQuery ||
        title.includes(currentSearchQuery) ||
        artists.includes(currentSearchQuery) ||
        types.includes(currentSearchQuery);

      const matchesFavorites = !filterOnlyFavorites || isFavorited;

      if (matchesSearch && matchesFavorites) {
        htmlCard.style.display = '';
      } else {
        htmlCard.style.display = 'none';
      }
    });
  }

  // <Handle-Filters>
  document.addEventListener('search-change', (event: any) => {
    currentSearchQuery = event.detail.query.trim().toLowerCase();
    applyFilters();
  });

  document.addEventListener('favorites-toggle', (event: any) => {
    filterOnlyFavorites = event.detail.onlyFavorites;
    applyFilters();
  });
  // </Handle-Filters>

  // <Handle-Favorites-On-Page-Load>
  const getStoredFavorites = (): Record<string, boolean> => {
    try {
      const stored = localStorage.getItem(STORAGE_KEY);
      return stored ? JSON.parse(stored) : {};
    } catch {
      return {};
    }
  };

  const saveStoredFavorites = (favorites: Record<string, boolean>) => {
    localStorage.setItem(STORAGE_KEY, JSON.stringify(favorites));
  };

  const favorites = getStoredFavorites();

  songCards.forEach(card => {
    const htmlCard = card as HTMLElement;
    const songId = htmlCard.id;

    if (favorites[songId]) {
      htmlCard.setAttribute('data-favorited', 'true');

      const emptyIcon = htmlCard.querySelector('.favorite-empty');
      const filledIcon = htmlCard.querySelector('.favorite-filled');
      emptyIcon?.classList.add('hidden');
      filledIcon?.classList.remove('hidden');
    }
  });

  // Re-read storage value just before running initial layout pass to bypass module runtime variance
  filterOnlyFavorites = localStorage.getItem(TOGGLE_STORAGE_KEY) === 'true';
  applyFilters();
  // </Handle-Favorites-On-Page-Load>

  // <Handle-Favorites-Toggle>
  const favoriteButtons = document.querySelectorAll('[data-favorite-btn]');

  favoriteButtons.forEach(btn => {
    btn.addEventListener('click', event => {
      event.preventDefault();
      event.stopPropagation();

      const buttonElement = btn as HTMLButtonElement;
      const card = buttonElement.closest('[data-song-card]') as HTMLElement;
      if (!card) return;

      const songId = card.id;
      const isFavorited = card.getAttribute('data-favorited') === 'true';
      const nextState = !isFavorited;

      card.setAttribute('data-favorited', String(nextState));

      const emptyIcon = buttonElement.querySelector('.favorite-empty');
      const filledIcon = buttonElement.querySelector('.favorite-filled');

      if (nextState) {
        emptyIcon?.classList.add('hidden');
        filledIcon?.classList.remove('hidden');
      } else {
        emptyIcon?.classList.remove('hidden');
        filledIcon?.classList.add('hidden');
      }

      const currentFavorites = getStoredFavorites();
      if (nextState) {
        currentFavorites[songId] = true;
      } else {
        delete currentFavorites[songId];
      }
      saveStoredFavorites(currentFavorites);

      applyFilters();
    });
  });
  // </Handle-Favorites-Toggle>
</script>
