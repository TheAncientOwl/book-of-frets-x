import type { TSong } from '#types/song';

interface Props {
  notes: TSong['notes'];
}

const { notes } = Astro.props;
const hasNotes = notes && notes.length > 0;
---

{
  hasNotes && (
    <details open class="group border-t border-solid border-gold w-full">
      <!-- Accordion Button / Header -->
      <summary class="flex justify-center items-center relative pt-3 pb-2 list-none cursor-pointer select-none bg-black/20">
        <h3 class="text-center font-bold text-lg text-gold capitalize flex flex-row items-center justify-center gap-[0.25em]">
          <!-- Quill Pen Left Icon -->
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5">
            <path d="M21 2c0 8.5-4.5 13.5-9 15.5V22h-2v-4.06c-.34-.05-.67-.13-1-.24l-3.32 3.32-1.42-1.42 3.32-3.32c-.11-.33-.19-.66-.24-1H3v-2h4.5c2-4.5 7-9 13.5-9H21zm-6.61 7.2L11 12.59l1.41 1.41 3.2-3.21a12.72 12.72 0 0 0-1.22-1.59z" />
          </svg>
          
          Notes
          
          <!-- Quill Pen Right Icon -->
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5">
            <path d="M21 2c0 8.5-4.5 13.5-9 15.5V22h-2v-4.06c-.34-.05-.67-.13-1-.24l-3.32 3.32-1.42-1.42 3.32-3.32c-.11-.33-.19-.66-.24-1H3v-2h4.5c2-4.5 7-9 13.5-9H21zm-6.61 7.2L11 12.59l1.41 1.41 3.2-3.21a12.72 12.72 0 0 0-1.22-1.59z" />
          </svg>
        </h3>

        <!-- Accordion Chevron Icon -->
        <span class="absolute right-[10px] text-gold transition-transform duration-200 group-open:rotate-180">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5">
            <polyline points="6 9 12 15 18 9" />
          </svg>
        </span>
      </summary>

      <!-- Accordion Panel / Content Layout -->
      <div class="p-4 pt-3 pb-4">
        <div class="p-[0.25em_0.5em] mb-4">
          <ul class="text-center text-gold text-sm flex flex-col items-center w-full">
            {
              notes.map((note, index) => (
                <>
                  <li class="w-full">{note}</li>
                  {index < notes.length - 1 && (
                    <hr class="w-full my-4 border-t border-solid border-gold/10" />
                  )}
                </>
              ))
            }
          </ul>
        </div>
      </div>
    </details>
  )
}

<style>
  /* Hide standard disclosure indicator arrows across browsers */
  summary::-webkit-details-marker {
    display: none;
  }
</style>
