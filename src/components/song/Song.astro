import type { TSong } from '#types/song';

import SongHeader from '#components/song/Header.astro';
import SongNotes from './Notes.astro';
import SongChordsList from '#components/song/ChordsLists.astro';
import SongSections from '#components/song/sections/Sections.astro';
import SongResources from './SongResources.astro';

interface Props extends TSong {
  directory: string;
}

const props = Astro.props;

import type { TChord } from '#types/chord';
import chordsIndexData from '#public/chords/index.json';
const chordsIndex = chordsIndexData.index as Record<string, any>;
---

<div
  id='song-viewport-container'
  class='w-full min-h-dvh overflow-y-auto bg-deep-charcoal p-2 md:p-4 flex flex-col items-center justify-start'
>
  <div
    class='rounded-xl bg-deep-purple p-4 min-h-dvh w-full max-w-5xl flex flex-col justify-between gap-6'
  >
    <div>
      <SongHeader
        directory={props.directory}
        title={props.title}
        artists={props.artists}
        capo={props.capo}
        type={props.type}
        contributors={props.contributors}
        lyrics={props.lyrics}
        lyricsShown={false}
        res={props.res}
      />

      <div class='rounded-xl overflow-hidden bg-black/20 p-3 mt-4'>
        <SongNotes notes={props.notes} />
        <SongChordsList chordIDs={props.chordIDs} />

        <SongSections
          chordsIndex={chordsIndex}
          songSettings={{
            display: {
              strummingPattern: true,
              chordTimes: true,
              chordTimesOne: true,
            },
          }}
          sections={props.sections}
          order={props.order}
          strumms={props.strumms}
          showLyrics={false}
          lyrics={[]}
        />
      </div>
    </div>

    <div
      id='lazy-resources-wrapper'
      class='mt-auto pt-6 border-t border-solid border-white/5 min-h-[200px]'
    >
      <template id='song-resources-template'>
        <SongResources res={props.res} />
      </template>
    </div>
  </div>
</div>

<script>
  function setupLazyResources() {
    const rootContainer = document.getElementById('song-viewport-container');
    const wrapper = document.getElementById('lazy-resources-wrapper');
    const template = document.getElementById(
      'song-resources-template',
    ) as HTMLTemplateElement | null;

    if (!rootContainer || !wrapper || !template) return;

    const observerOptions = {
      root: rootContainer,
      rootMargin: '300px 0px', // Start streaming the iframe packages slightly before reaching bottom
      threshold: 0.01,
    };

    const observer = new IntersectionObserver((entries, self) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          // Clone and insert the real SongResources component DOM node tree
          const clone = template.content.cloneNode(true);
          wrapper.appendChild(clone);
          template.remove();

          // Disconnect completely since we only need to load the scripts once
          self.disconnect();
        }
      });
    }, observerOptions);

    observer.observe(wrapper);
  }

  // Bind execution parameters cleanly across classic navigations and transitions
  setupLazyResources();
  document.addEventListener('astro:after-swap', setupLazyResources);
</script>
