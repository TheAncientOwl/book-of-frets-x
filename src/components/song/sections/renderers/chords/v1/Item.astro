import type { TStrummingChordsItem, TStrummingPattern } from '#types/song';
import ChordPopover from '#components/common/ChordPopover.astro';
import type { TChord } from '#types/chord';

interface Props {
  items: TStrummingChordsItem;
  strumms: TStrummingPattern[];
  chordsIndex: Record<string, TChord>;
  songSettings: {
    display: {
      strummingPattern: boolean;
      chordTimes: boolean;
      chordTimesOne: boolean;
    };
  };
}

const { items, strumms, chordsIndex, songSettings } = Astro.props;

const EMPHASIZE_STRUMS = ['De', 'Ue'];
const EMPHASIZE_STRUM_CHAR = 'e';
const SEPARATOR_CHORD_CHAR = '|';
const SEPARATOR_BREAK_LINE = '/';
const NO_CHORD_ID = '-';

const mapPairs = <T, R>(array: T[], callback: (a: T, b: T, index: number) => R): R[] => {
  const result: R[] = [];
  for (let idx = 2; idx < array.length; idx += 2) {
    result.push(callback(array[idx - 1], array[idx], idx - 1));
  }
  return result;
};

const linesData = items.map(lineData => lineData.map(data => data.split(' ')));
---

<div class='flex flex-row items-end justify-center gap-5'>
  {
    linesData.map((lineData, lineIdx) => {
      const strumm = Number(lineData[0][0]);

      if (strumm >= strumms.length) {
        console.error({
          message: `Found strum index ${strumm} when strumms length is ${strumms.length}`,
          strumms: strumms,
        });
        return null;
      }

      const strummingPattern = strumms[strumm];

      return (
        <div class='flex flex-col justify-center items-center gap-2'>
          <div class='flex flex-col gap-5'>
            {lineData.map((data, dataIdx) => (
              <div class='flex flex-row gap-5 justify-center'>
                {mapPairs(data, (chordId, times, pairIdx) => {
                  if (chordId === SEPARATOR_CHORD_CHAR) {
                    return <div class='h-5.5 w-0 border-l border-solid border-gold/60' />;
                  }

                  if (chordId === SEPARATOR_BREAK_LINE) {
                    return <br />;
                  }

                  const chordConfig = chordsIndex[chordId];

                  if (chordConfig === undefined) {
                    console.error(`Missing chord index for ID '${chordId}'`);
                  }

                  // Generate a strictly unique ID string instance per iteration mapping loop keys
                  const popoverUniqueId = `popover-${lineIdx}-${dataIdx}-${pairIdx}-${chordId}`;

                  return (
                    <div class='relative inline-block select-none'>
                      <button
                        type='button'
                        popovertarget={popoverUniqueId}
                        class='chord-popover-trigger appearance-none outline-none mt-2.5 px-1.5 py-0.5 font-bold rounded cursor-pointer whitespace-nowrap bg-dark-magenta text-gold hover:bg-dark-magenta/70 transition-colors relative border-none'
                      >
                        {chordId !== NO_CHORD_ID && chordConfig !== undefined
                          ? chordConfig.name
                          : '-'}

                        {songSettings.display.chordTimes &&
                          (times !== '1' || songSettings.display.chordTimesOne) && (
                            <span
                              class='absolute -top-2.5 right-0 translate-x-full text-xs font-bold text-gold'
                              title={`Strum ${times} times`}
                            >
                              {times}
                            </span>
                          )}
                      </button>

                      {chordConfig && (
                        <ChordPopover id={popoverUniqueId} chordConfig={chordConfig} />
                      )}
                    </div>
                  );
                })}
              </div>
            ))}
          </div>

          {songSettings.display.strummingPattern && (
            <div class='relative mt-[0.4em]'>
              <div class='flex flex-row gap-2 justify-center text-gold'>
                {strummingPattern.map(pattern => (
                  <span
                    class:list={[
                      'font-bold',
                      EMPHASIZE_STRUMS.includes(pattern) ? 'underline' : 'none',
                    ]}
                  >
                    {pattern.replace(EMPHASIZE_STRUM_CHAR, '')}
                  </span>
                ))}
              </div>
            </div>
          )}
        </div>
      );
    })
  }
</div>

<script>
  function setupPopoverAnchoring() {
    const triggers = document.querySelectorAll<HTMLButtonElement>('.chord-popover-trigger');

    triggers.forEach(trigger => {
      const targetId = trigger.getAttribute('popovertarget');
      if (!targetId) return;

      const popover = document.getElementById(targetId);
      if (!popover) return;

      // Handle custom alignment geometry on display action click updates
      trigger.addEventListener('click', () => {
        requestAnimationFrame(() => {
          const triggerRect = trigger.getBoundingClientRect();

          // Center horizontal, place 12px exactly above the trigger seam node
          popover.style.left = `${triggerRect.left + triggerRect.width / 2 - popover.offsetWidth / 2}px`;
          popover.style.top = `${triggerRect.top - popover.offsetHeight - 12 + window.scrollY}px`;
        });
      });
    });
  }

  setupPopoverAnchoring();
  document.addEventListener('astro:after-swap', setupPopoverAnchoring);
</script>
