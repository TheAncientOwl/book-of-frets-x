import Chord from '#components/common/Chord.astro';
import type { TChord } from '#types/chord';

interface Props {
  id: string; // Unique ID to associate target anchors with this modal popup
  chordConfig: TChord;
}

const { id, chordConfig } = Astro.props;
---

<div
  id={id}
  popover
  class='popover-top-layer p-4 rounded-lg border border-solid border-gold/60 bg-deep-purple shadow-xl overflow-visible max-w-none backdrop:bg-transparent'
>
  {/* Close button utility */}
  <button
    type='button'
    class='absolute top-2 right-2 text-gold/50 hover:text-gold text-xs font-mono outline-none cursor-pointer z-40'
    popovertarget={id}
    popovertargetaction='hide'
  >
    ✕
  </button>

  {
    /* 
    FIX: Removed 'w-30 h-35' restrictions. We isolate the font-size context 
    so the chord's internal 'em' metrics calculate perfectly.
  */
  }
  <div class='flex justify-center items-center text-[0.7em]'>
    <Chord {...chordConfig} />
  </div>
</div>

<style>
  /* 
    Styles specific to components rendering inside the native Top Layer.
  */
  .popover-top-layer {
    margin: 0;
    position: absolute;
    border-radius: 0.5rem;
    color: inherit;
    z-index: 50;
  }

  .popover-top-layer:not(:popover-open) {
    display: none;
  }
</style>
