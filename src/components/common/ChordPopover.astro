import Chord from '#components/common/Chord.astro';
import type { TChord } from '#types/chord';

interface Props {
  id: string;
  chordConfig: TChord;
}

const { id, chordConfig } = Astro.props;
---

<div
  id={id}
  popover
  class='fixed !inset-0 !m-0 p-0 w-dvw h-dvh max-w-none max-h-none border-none bg-transparent backdrop:bg-black/65 open:flex items-center justify-center z-50 cursor-pointer'
>
  <div
    class='relative p-8 rounded-lg border border-solid border-gold/60 bg-deep-purple shadow-2xl overflow-visible cursor-default'
  >
    <button
      type='button'
      class='absolute top-2 right-2 text-gold/50 hover:text-gold text-xs font-mono outline-none cursor-pointer z-40'
      popovertarget={id}
      popovertargetaction='hide'
    >
      ✕
    </button>

    <div class='flex items-center justify-center text-[0.7em] max-w-full h-auto mx-auto'>
      <Chord {...chordConfig} />
    </div>
  </div>
</div>

<script>
  const setupPopoverDismissal = () => {
    const popovers = document.querySelectorAll('[popover]');

    popovers.forEach(popover => {
      popover.removeEventListener('click', handleAnywhereClick);
      popover.addEventListener('click', handleAnywhereClick);
    });
  };

  function handleAnywhereClick(event: Event) {
    const popover = event.currentTarget as any;
    if (typeof popover.hidePopover === 'function') {
      popover.hidePopover();
    }
  }

  setupPopoverDismissal();
  document.addEventListener('astro:page-load', setupPopoverDismissal);
</script>
