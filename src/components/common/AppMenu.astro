import { Icon } from 'astro-icon/components';
---

<!-- 1. Floating Trigger Button -->
<button
  id='menu-trigger-btn'
  aria-label='App Menu'
  class='fixed top-4 left-4 z-[200] w-[45px] h-[45px] p-[3px] rounded-[10px]
        border border-solid border-neon-purple cursor-pointer
        transition-colors duration-200
        bg-black/15 hover:bg-black/40
        text-gold'
>
  <img
    src={`${import.meta.env.BASE_URL}logo.svg`}
    alt='Book of Frets theme logo'
    class='w-full h-full object-cover rounded-[7px]'
  />
</button>

<!-- 2. The Drawer Dialog Scaffolding -->
<dialog
  id='app-menu-drawer'
  class='fixed left-0 m-0 top-0 bottom-0 w-full max-w-xs h-dvh m-0 max-h-none
        flex flex-col
        bg-deep-purple p-0 shadow-2xl
        transition-transform duration-300 -translate-x-full
        backdrop:bg-black/60 open:translate-x-0'
>
  <!-- Header -->
  <header class='flex items-center justify-between p-4 sticky top-0 z-[110] bg-deep-purple'>
    <div class='flex items-center gap-2'>
      <img
        src={`${import.meta.env.BASE_URL}logo.svg`}
        alt='Book of Frets Logo'
        class='max-w-[25px]'
      />
      <span class='font-bold text-gold text-xl'>Book Of Frets</span>
    </div>
    <button
      id='menu-close-btn'
      class='p-1 text-gold hover:text-magenta transition-colors cursor-pointer'
      aria-label='Close menu'
    >
      <Icon name='material-symbols:close' class='w-6 h-6' />
    </button>
  </header>

  <!-- Tabs Navigation Area -->
  <div
    class='flex border-b border-solid border-neon-purple/20 sticky top-[57px] z-[110] bg-deep-purple'
  >
    <button
      data-tab-trigger='0'
      class='flex-1 py-3 text-center font-bold text-sm border-b-2 border-transparent text-gold cursor-pointer transition-colors duration-200'
    >
      Navigation
    </button>
    <button
      data-tab-trigger='1'
      class='flex-1 py-3 text-center font-bold text-sm border-b-2 border-transparent text-gold cursor-pointer transition-colors duration-200'
    >
      Tuner
    </button>
    <button
      data-tab-trigger='2'
      class='flex-1 py-3 text-center font-bold text-sm border-b-2 border-transparent text-gold cursor-pointer transition-colors duration-200'
    >
      Settings
    </button>
  </div>

  <!-- Scrollable Panels Container -->
  <div class='flex-1 overflow-y-auto p-4'>
    <!-- Panel 0: Navigation -->
    <div data-tab-panel='0' class='hidden'>
      <!-- <NavigationList /> -->
      <div class='text-white/70 py-2'>Navigation routes list here...</div>
      <hr class='my-4 border-neon-purple/20' />
    </div>

    <!-- Panel 1: Tuner -->
    <div data-tab-panel='1' class='hidden'>
      <div class='text-white/70 py-2'>Guitar Tuner interface loading...</div>
    </div>

    <!-- Panel 2: Settings -->
    <div data-tab-panel='2' class='hidden'>
      <div class='text-white/70 py-2'>Theme and Audio configuration settings...</div>
    </div>
  </div>

  <!-- Footer -->
  <footer
    class='p-4 border-t border-solid border-neon-purple/20 flex justify-center bg-deep-purple'
  >
    <a
      href='https://github.com/TheAncientOwl/book-of-frets-x/blob/main/LICENSE'
      target='_blank'
      rel='noopener noreferrer'
      class='flex items-center gap-1 text-sm text-gold hover:text-magenta transition-colors duration-200'
    >
      Copyright <Icon name='material-symbols:copyright-outline' class='w-4 h-4' /> 2026 BookOfFrets
    </a>
  </footer>
</dialog>

<script>
  const drawer = document.getElementById('app-menu-drawer') as HTMLDialogElement;
  const triggerBtn = document.getElementById('menu-trigger-btn');
  const closeBtn = document.getElementById('menu-close-btn');

  const tabTriggers = document.querySelectorAll('[data-tab-trigger]');
  const tabPanels = document.querySelectorAll('[data-tab-panel]');

  const STORAGE_KEY = 'book-of-frets-menu-active-tab';

  // --- Drawer Open / Close Logic ---
  triggerBtn?.addEventListener('click', () => {
    drawer?.showModal();
    document.body.style.overflow = 'hidden'; // Stop background scroll
  });

  const closeDrawer = () => {
    drawer?.close();
    document.body.style.overflow = '';
  };

  closeBtn?.addEventListener('click', closeDrawer);

  // Close when clicking backdrop shadow area
  drawer?.addEventListener('click', e => {
    if (e.target === drawer) closeDrawer();
  });

  // --- Session Tab Switching Logic ---
  const setActiveTab = (index: number) => {
    sessionStorage.setItem(STORAGE_KEY, String(index));

    tabTriggers.forEach((btn, idx) => {
      const htmlBtn = btn as HTMLButtonElement;
      htmlBtn.classList.add('text-gold');
      if (idx === index) {
        htmlBtn.classList.add('border-gold');
        htmlBtn.classList.remove('border-transparent');
      } else {
        htmlBtn.classList.remove('border-gold');
        htmlBtn.classList.add('border-transparent');
      }
    });

    tabPanels.forEach((panel, idx) => {
      const htmlPanel = panel as HTMLElement;
      if (idx === index) {
        htmlPanel.classList.remove('hidden');
      } else {
        htmlPanel.classList.add('hidden');
      }
    });
  };

  // Initialize tabs from sessionStorage on load
  const initialTab = parseInt(sessionStorage.getItem(STORAGE_KEY) || '0', 10);
  setActiveTab(initialTab);

  // Attach click events to tabs
  tabTriggers.forEach(trigger => {
    trigger.addEventListener('click', () => {
      const index = parseInt((trigger as HTMLElement).dataset.tabTrigger || '0', 10);
      setActiveTab(index);
    });
  });
</script>
