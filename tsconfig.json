{
  "extends": "astro/tsconfigs/strict",
  "include": [".astro/types.d.ts", "**/*"],
  "exclude": ["dist"],
  "compilerOptions": {
    "paths": {
      "#styles/*": ["./src/styles/*"],
      "#types/*": ["./src/types/*"],
      "#layouts/*": ["./src/layouts/*"],
      "#components/*": ["./src/components/*"],
      "#public/*": ["./public/*"]
    }
  }
}
